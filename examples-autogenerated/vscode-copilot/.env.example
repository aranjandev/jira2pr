# Environment variables for vscode-copilot AI agent setup
# Copy this file to .env at your project root (same directory as .git/) and fill in your values.
# Never commit your .env file — add it to .gitignore.
#   echo '.env' >> .gitignore

# ──────────────────────────────────────────────────────────
# JIRA
# ──────────────────────────────────────────────────────────

# Base URL of your JIRA instance (no trailing slash)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Email address associated with your JIRA account
# Also accepted as JIRA_USER (legacy alias)
JIRA_EMAIL=you@yourcompany.com

# JIRA API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# ──────────────────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────────────────

# GitHub personal access token (required for PR creation via REST API)
# Recommended: fine-grained PAT scoped to your target repo with "Pull requests: Read & Write"
#   Generate at: https://github.com/settings/tokens?type=beta
# Alternative: classic PAT with "public_repo" (public repos) or "repo" (private repos)
#   Generate at: https://github.com/settings/tokens
# Note: GitHub CLI (gh) auth is another alternative — run: gh auth login
GITHUB_TOKEN=your-github-token-here

# ──────────────────────────────────────────────────────────
# Bitbucket
# ──────────────────────────────────────────────────────────

# Bitbucket personal access token (required for PR creation via REST API)
# Generate at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_TOKEN=your-bitbucket-token-here
BITBUCKET_USERNAME=your-bitbucket-username-here